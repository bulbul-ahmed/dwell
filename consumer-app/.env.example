DATABASE_URL=
NEXT_PUBLIC_GOOGLE_MAPS_KEY=

# JWT — generate a strong secret: openssl rand -base64 32
JWT_SECRET=

# App URL (used for OAuth redirect URIs)
NEXT_PUBLIC_APP_URL=

# Google OAuth — get from https://console.cloud.google.com/
# Authorized redirect URI: http://localhost:3001/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Resend — get from https://resend.com/api-keys (3,000 free/month)
# Without this, emails are logged to server console (dev mode)
RESEND_API_KEY=
EMAIL_FROM=

# Stream Chat — get keys from https://getstream.io/dashboard/
NEXT_PUBLIC_STREAM_API_KEY=
STREAM_API_KEY=
STREAM_API_SECRET=
